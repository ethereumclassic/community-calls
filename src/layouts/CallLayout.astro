---
import type { Call } from "../lib/types";
import PageLayout from "./PageLayout.astro";
import AnimatedContainer from "../components/AnimatedContainer.astro";
import CallNavigation from "../components/CallNavigation.astro";
import CallHeader from "../components/CallHeader.astro";
import CallRoster from "../components/CallRoster.astro";
import YouTubeEmbed from "../components/YouTubeEmbed.astro";
import JoinCallModal from "../components/JoinCallModal.astro";
import ShareModal from "../components/ShareModal.astro";
import { formatShortDate, formatTime, getTimezoneDateNote } from "../lib/dates";
// import HostList from "../components/HostList.astro";

interface Props {
  call: Call;
  prevCall?: Call | null;
  nextCall?: Call | null;
  upcomingCall?: Call | null;
}

const { call, prevCall, nextCall, upcomingCall } = Astro.props;

const callNumber = call.data.callNumber!;
const youtubeId = call.data.youtubeId;
const isUpcoming = call.data.isUpcoming;
const joinModalId = `join-call-modal-${callNumber}`;
const shareModalId = `share-modal-${callNumber}`;

const title = call.data.special
  ? `Special Event - ${call.data.description}`
  : call.data.description
    ? `ETCCC ${callNumber} - ${call.data.description}`
    : `ETCCC ${callNumber}`;
const timezoneNote = getTimezoneDateNote(call.data.date, call.data.time);
const ogDescription = `${formatShortDate(call.data.date)} at ${formatTime(call.data.time)}${timezoneNote}`;
---

<PageLayout title={title} description={ogDescription} maxWidth="narrow">
  <AnimatedContainer as="article" delay={100}>
    <CallNavigation
      prevCall={prevCall}
      nextCall={nextCall}
      currentCall={call}
      upcomingCall={upcomingCall}
    />

    <CallHeader call={call} />

    {
      call.data.roster && call.data.roster.length > 0 && (
        <CallRoster roster={call.data.roster} />
      )
    }

    {
      youtubeId && (
        <YouTubeEmbed
          youtubeId={youtubeId}
          date={call.data.date}
          callNumber={callNumber}
          title={title}
        />
      )
    }

    <!-- Hosts - temporarily hidden
    {call.data.hosts && call.data.hosts.length > 0 && (
      <HostList hosts={call.data.hosts} />
    )}
    -->

    <!-- Main Content -->
    <AnimatedContainer
      as="section"
      delay={400}
      class="prose md:prose-lg prose-invert max-w-none"
    >
      <slot />
    </AnimatedContainer>
  </AnimatedContainer>

  <!-- Modals (rendered at root level for proper backdrop) -->
  {
    isUpcoming && call.data.joinLink && !call.data.youtube && (
      <JoinCallModal slot="modals" call={call} modalId={joinModalId} />
    )
  }
  {
    isUpcoming && !call.data.youtube && (
      <ShareModal slot="modals" call={call} modalId={shareModalId} />
    )
  }
</PageLayout>

<script>
  document.querySelectorAll(".transcript-wrapper").forEach((wrapper) => {
    const btn = document.createElement("button");
    btn.className = "transcript-expand";
    if (wrapper.classList.contains("transcript-chaptered")) {
      // Chaptered: expand/collapse every chapter's <details> at once.
      btn.textContent = "Expand All Chapters";
      btn.addEventListener("click", () => {
        const ds = wrapper.querySelectorAll("details.transcript-chapter");
        if (!ds.length) return;
        const open = [...ds].some((d) => !(d as HTMLDetailsElement).open);
        ds.forEach((d) => ((d as HTMLDetailsElement).open = open));
        btn.textContent = open
          ? "Collapse All Chapters"
          : "Expand All Chapters";
      });
    } else {
      // Flat: lift the scroll cap to show the whole transcript.
      btn.textContent = "Expand Full Transcript";
      btn.addEventListener("click", () => {
        wrapper.classList.toggle("expanded");
        btn.textContent = wrapper.classList.contains("expanded")
          ? "Collapse Transcript"
          : "Expand Full Transcript";
      });
    }
    wrapper.appendChild(btn);
  });
</script>
