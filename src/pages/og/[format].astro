---
// OG Image pages - for taking screenshots in various social media formats
import "../../styles/index.css";
import "@fontsource-variable/jetbrains-mono";
import "@fontsource/instrument-serif/400.css";
import "@fontsource/instrument-serif/400-italic.css";

const formats: Record<
  string,
  { width: number; height: number; label: string }
> = {
  landscape: { width: 1200, height: 630, label: "Facebook / LinkedIn / OG" },
  square: { width: 1200, height: 1200, label: "Square" },
  twitter: { width: 1200, height: 675, label: "Twitter / X" },
  portrait: { width: 1080, height: 1350, label: "Portrait" },
  wide: { width: 1200, height: 600, label: "Slack" },
};

export function getStaticPaths() {
  return ["landscape", "square", "twitter", "portrait", "wide"].map(
    (format) => ({ params: { format } }),
  );
}

const { format } = Astro.params;
const fmt = formats[format!];
if (!fmt) return Astro.redirect("/og/landscape");

const isSquareOrTall = fmt.height >= fmt.width;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ETC Community Calls - OG {fmt.label}</title>
    <style define:vars={{ w: `${fmt.width}px`, h: `${fmt.height}px` }}>
      body {
        width: var(--w);
        height: var(--h);
        overflow: hidden;
        margin: 0;
        padding: 0;
      }

      body::before {
        display: none;
      }

      .og-container {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 64px;
        padding: 48px 64px;
        position: relative;
        z-index: 10;
      }

      .og-container.vertical {
        flex-direction: column;
        gap: 40px;
        padding: 32px 32px;
      }

      .bg-pattern {
        position: absolute;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
        opacity: 0.03;
      }

      .bg-pattern svg {
        width: 100%;
        height: 100%;
      }

      .logo-section {
        position: relative;
        flex-shrink: 0;
        display: inline-block;
      }

      .logo-glow {
        position: absolute;
        inset: 0;
        background: rgba(111, 207, 151, 0.2);
        border-radius: 9999px;
        filter: blur(48px);
        transform: scale(1.5);
      }

      .logo {
        position: relative;
        width: 180px;
        height: 180px;
      }

      .vertical .logo {
        width: 260px;
        height: 260px;
      }

      .vertical .og-title {
        font-size: 80px;
      }

      .vertical .og-subtitle {
        font-size: 24px;
        max-width: 960px;
      }

      .text-section {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .vertical .text-section {
        align-items: center;
        text-align: center;
      }

      .og-title {
        font-family: "Instrument Serif", Georgia, serif;
        font-weight: 400;
        font-size: 64px;
        line-height: 1.1;
        letter-spacing: -0.01em;
        color: #f3f4f6;
        margin: 0 0 24px 0;
      }

      .og-title-glow {
        color: var(--color-etc-green);
        text-shadow:
          0 0 10px var(--color-etc-green-glow),
          0 0 20px var(--color-etc-green),
          0 0 40px var(--color-etc-green-dim);
      }

      .og-subtitle {
        font-family: "JetBrains Mono Variable", ui-monospace, monospace;
        font-size: 20px;
        color: #9ca3af;
        line-height: 1.5;
        max-width: 600px;
        margin: 0;
      }

      .og-subtitle .highlight {
        color: rgba(111, 207, 151, 0.9);
      }

      .border-frame {
        position: absolute;
        inset: 16px;
        border: 1px solid rgba(111, 207, 151, 0.15);
        border-radius: 12px;
        pointer-events: none;
      }

      .corner {
        position: absolute;
        width: 32px;
        height: 32px;
        border-color: var(--color-etc-green);
        opacity: 0.4;
      }

      .corner-tl {
        top: 16px;
        left: 16px;
        border-top: 2px solid;
        border-left: 2px solid;
      }

      .corner-tr {
        top: 16px;
        right: 16px;
        border-top: 2px solid;
        border-right: 2px solid;
      }

      .corner-bl {
        bottom: 16px;
        left: 16px;
        border-bottom: 2px solid;
        border-left: 2px solid;
      }

      .corner-br {
        bottom: 16px;
        right: 16px;
        border-bottom: 2px solid;
        border-right: 2px solid;
      }
    </style>
  </head>
  <body>
    <div class="bg-pattern">
      <svg
        viewBox={`0 0 ${fmt.width} ${fmt.height}`}
        preserveAspectRatio="none"
      >
        <path
          d={`M0,${fmt.height * 0.5} L${fmt.width * 0.25},${fmt.height * 0.5} L${fmt.width * 0.29},${fmt.height * 0.32} L${fmt.width * 0.71},${fmt.height * 0.32} L${fmt.width * 0.75},${fmt.height * 0.5} L${fmt.width},${fmt.height * 0.5}`}
          stroke="#6fcf97"
          stroke-width="2"
          fill="none"></path>
        <path
          d={`M0,${fmt.height * 0.71} L${fmt.width * 0.17},${fmt.height * 0.71} L${fmt.width * 0.21},${fmt.height * 0.6} L${fmt.width * 0.38},${fmt.height * 0.6} L${fmt.width * 0.42},${fmt.height * 0.71} L${fmt.width},${fmt.height * 0.71}`}
          stroke="#6fcf97"
          stroke-width="2"
          fill="none"></path>
      </svg>
    </div>

    <div class="border-frame"></div>

    <div class="corner corner-tl"></div>
    <div class="corner corner-tr"></div>
    <div class="corner corner-bl"></div>
    <div class="corner corner-br"></div>

    <div class:list={["og-container", { vertical: isSquareOrTall }]}>
      <div class="logo-section">
        <div class="logo-glow"></div>
        <img src="/etc-logo.svg" alt="ETC Logo" class="logo" />
      </div>

      <div class="text-section">
        <h1 class="og-title">
          <span>Ethereum Classic</span><br />
          <span class="og-title-glow">Community Calls</span>
        </h1>
        <p class="og-subtitle">
          Regular open discussions about development,<br />
          <span class="highlight">ECIPs</span>, and the future of
          <span class="highlight">Ethereum Classic</span>
        </p>
      </div>
    </div>
  </body>
</html>
